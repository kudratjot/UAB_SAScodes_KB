/*Younden's J index*/
/*ppv= tp/(tp+fp)
npv=tn+(tn+fn)*/
data roc2;
set rocstats;
logit=log(_PROB_/(1-_PROB_));
smg_cutt = (logit+2.7301)/7.7311;
sensitivity = _SENSIT_ ;
specificity = 1 - _1MSPEC_ ;
YJ = sensitivity+specificity-1;
ppv= _POS_/(_POS_+_FALPOS_);
npv= _NEG_/(_NEG_+_FALNEG_);
run;

proc sort data=roc2;by descending YJ;run;

proc print data=roc2(obs=1);
var _PROB_ sensitivity specificity ppv npv YJ smg_cutt;
run;

Ods rtf close;


