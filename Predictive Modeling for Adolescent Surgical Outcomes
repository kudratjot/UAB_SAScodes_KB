/* === 5. Effect Size Estimation === */
proc means data=tos2 mean std median ;
var VAS_diff QuickDASH_diff CBSQ_diff;
output out=cohen;
run;
proc transpose data=cohen out=tcohen;
id _STAT_;
var VAS_diff QuickDASH_diff CBSQ_diff;
run;
data tcohen;set tcohen;
CohenD=MEAN/STD;
run; 
proc print data=tcohen;run;
/*0.2=small effect , 0.5=medium , 0.8+=large*/

/* === 6. Spearman Correlation Between Change Scores === */
proc corr data=tos2 spearman;
var VAS_diff QuickDASH_diff CBSQ_diff;
run;
/*The coefficient ranges from -1 to +1, with positive values indicating a positive monotonic relationship 
and negative values indicating a negative monotonic relationship. Values closer to 1 or -1 represent stronger 
relationships, while values closer to 0 indicate weaker relationships*/
/*p-value may not reach 0.05 due to small sample size, but rho can tell us about the relation*/

/* === 7. Responder Frequency and Comparison === */
proc freq data=tos2;
tables Any2Scale_improve;
run;

