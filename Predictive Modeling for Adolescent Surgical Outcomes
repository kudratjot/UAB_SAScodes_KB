proc import out=tos
    datafile="---\DATA\copy_tos.csv"
    dbms=csv
    replace;
    getnames=YES;
run;

proc means data=tos2 n nmiss mean std min max maxdec=2; var _numeric_; run;

proc freq data=tos;
tables Reduction_of_Symptoms*Nerve_Blocks;
run;

proc means data=tos;
var QuickDASH_Pre_Nerve_Block QuickDASH_Post_Nerve_Block;
run;

/*Cutoff Scores:
These thresholds are generally used for subgroups:
VAS: 0-3 = mild, 4-6 = moderate, 7-10 = severe
QuickDASH: 0-20 = mild, 21-40 = moderate, 41-100 = severe
CBSQ: no commonly used threshold cutoff available since it is less standardized*/

data tos2;set tos;
length pre_vas $10. Post_vas $10.  pre_QuickDASH $10.  post_QuickDASH $10. VAS_test $12. QuickDASH_test $12. CBSQ_test $12. Any2Scale_improve $12.;
if name='VG' then do;
VAS_Pre_Nerve_Block = 3;
QuickDASH_Pre_Nerve_Block = 48.6;
CBSQ_Pre_Nerve_Block = 68.3;
end;

if VAS_Pre_Nerve_Block in(0,1,2,3) then pre_vas='Mild';
else if VAS_Pre_Nerve_Block in(4,5,6) then pre_vas='Moderate';
else if VAS_Pre_Nerve_Block in(7,8,9,10) then pre_vas='Severe';
if VAS_Post_Nerve_Block in(0,1,2,3) then Post_vas='Mild';
else if VAS_Post_Nerve_Block in(4,5,6) then Post_vas='Moderate';
else if VAS_Post_Nerve_Block in(7,8,9,10) then Post_vas='Severe';

if QuickDASH_Pre_Nerve_Block <= 20 then pre_QuickDASH='Mild';
else if 21<= QuickDASH_Pre_Nerve_Block <=40 then pre_QuickDASH='Moderate';
else if QuickDASH_Pre_Nerve_Block >40 then pre_QuickDASH='Severe';
if QuickDASH_Post_Nerve_Block <= 20 then post_QuickDASH='Mild';
else if 21<=QuickDASH_Post_Nerve_Block <=40 then post_QuickDASH='Moderate';
else if QuickDASH_Post_Nerve_Block >40 then post_QuickDASH='Severe';

if VAS_Pre_Nerve_Block>=VAS_Post_Nerve_Block then VAS_test =1;
else VAS_test =0;
if QuickDASH_Pre_Nerve_Block>=QuickDASH_Post_Nerve_Block then QuickDASH_test =1;
else QuickDASH_test =0;
if CBSQ_Pre_Nerve_Block>=CBSQ_Post_Nerve_Block then CBSQ_test =1;
else CBSQ_test =0;

num_improve=sum(VAS_test,QuickDASH_test,CBSQ_test );

if num_improve>=2 then Any2Scale_improve='yes';
else Any2Scale_improve='no';

if Any2Scale_improve='yes' then improvement=1;
else if Any2Scale_improve='no' then improvement=0;

VAS_diff = VAS_Post_Nerve_Block - VAS_Pre_Nerve_Block;
QuickDASH_diff = QuickDASH_Post_Nerve_Block- QuickDASH_Pre_Nerve_Block;
CBSQ_diff = CBSQ_Post_Nerve_Block-  CBSQ_Pre_Nerve_Block;

if VAS_Pre_Nerve_Block>0 then vas_pct=(VAS_diff/VAS_Pre_Nerve_Block)*100;
else if (VAS_Pre_Nerve_Block=0) and (VAS_Post_Nerve_Block>0) then vas_pct= -100;
else if (VAS_Pre_Nerve_Block=0) and (VAS_Post_Nerve_Block=0) then vas_pct= 0;

QuickDASH_pct=(QuickDASH_diff/QuickDASH_Pre_Nerve_Block)*100;
CBSQ_pct=(CBSQ_diff/CBSQ_Pre_Nerve_Block)*100;

if Reduction_of_Symptoms='yes' then Reduction_of_Symptoms_n=1;
else if Reduction_of_Symptoms='no' then Reduction_of_Symptoms_n=0;

if Resolution_of_Symptoms_after_sur=' ' then Resolution_of_Symptoms_aft_sur_n='Missing';
else Resolution_of_Symptoms_aft_sur_n=Resolution_of_Symptoms_after_sur;

run;

proc FREQ data=tos2;TABLES  Resolution_of_Symptoms_aft_sur_n ;
run;

proc sgplot data=tos2;
vbar Any2Scale_improve /group=Resolution_of_Symptoms_aft_sur_n groupdisplay=cluster;
xaxis  label='Responder status(Imptoved at any 2 scale=yes else no)';
yaxis  label='Number of Responder';
run;

