%macro categ(pred=,i=,); 

*freq;
proc freq data=&file.;
table Anticoagulation/out=out;
run;

proc freq data=&file.;
table &pred/out=p_freq&i;
run;
data p2_freq&i;set p_freq&i;
rcount = put(count,8.); 
numpct = strip(round(percent,0.1))||"% ("||strip(rcount)|| ")" ; 
index=&i;
keep index numpct;
run;

proc freq data = &file.; 
tables &pred *  Anticoagulation/ missing chisq sparse outpct out = outfreq&i ; 
output out = stats&i chisq fisher; 
exact fisher;
run; 

proc sort data=outfreq&i; by &class.;run;

data comb&i.;
merge outfreq&i.(in=a) out(in=b keep=&class. count rename=(count=sub_count));
by Anticoagulation;
if a;
run;

data routfreq&i(rename = (&pred = variable)); 
set comb&i; 
length varname $20.; 
rcount = put(count,8.); 
rsub_count = put(sub_count,8.); 
numpct = strip(round(pct_col,0.1))||"% ("||strip(rcount) || ")" ; 
index = &i; 
varname = vlabel(&pred); 
keep &pred numpct index varname &class.; 
run; 

proc sort data = routfreq&i; 
by variable; 
run; 
 
proc transpose data=routfreq&i out=woutfreq&i; 
by variable index; 
id Anticoagulation;
var numpct;
run;
data rstats&i; 
set stats&i; 
length p_value $8.; 
/* if P_PCHI <= 0.05 then do; */
/*p_value = put(round(P_PCHI,0.0001),6.4) || "*";  */
if XP2_FISH < 0.0001 then p_value = "<0.0001" || "*"; 
else p_value = put(XP2_FISH,8.4); 
keep p_value index; 
index = &i; 
run; 
data final&i; 
length varname $20.;
merge woutfreq&i rstats&i; 
by index; 
varname="&pred.";
if not first.index then do; 
varname = " "; 
p_value = " "; 
end; 
run;

data finalg&i;
merge final&i p2_freq&i;
by index;
run;
